@page
@model BeeMemoryBank.Web.Pages.UsersModel
@{
    ViewData["Title"] = "Users";
}

<partial name="_Sidebar" />

<div id="page-content">
<div class="main-content">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h2 style="margin:0;"><sl-icon name="people"></sl-icon> Users</h2>
        <sl-button size="small" variant="success" onclick="openAddUser()">
            <sl-icon slot="prefix" name="plus-lg"></sl-icon> Add User
        </sl-button>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <sl-alert variant="success" open closable style="margin-bottom:20px;">
            <sl-icon slot="icon" name="check-circle"></sl-icon>
            @Model.SuccessMessage
        </sl-alert>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <sl-alert variant="danger" open closable style="margin-bottom:20px;">
            <sl-icon slot="icon" name="exclamation-triangle"></sl-icon>
            @Model.ErrorMessage
        </sl-alert>
    }

    @if (Model.Users != null && Model.Users.Count > 0)
    {
        <div class="card" style="padding:0;overflow:hidden;">
            <table class="version-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Display Name</th>
                        <th>Role</th>
                        <th>Created</th>
                        <th>Last Login</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td><strong>@user.Username</strong></td>
                            <td>@user.DisplayName</td>
                            <td>
                                <sl-badge variant="@(user.Role == "superadmin" ? "warning" : "neutral")" pill>
                                    @user.Role
                                </sl-badge>
                            </td>
                            <td class="text-muted text-sm">@user.CreatedAt.ToString("g")</td>
                            <td class="text-muted text-sm">@(user.LastLoginAt?.ToString("g") ?? "—")</td>
                            <td style="text-align:right;">
                                @if (user.Role != "superadmin")
                                {
                                    <sl-icon-button name="shield-lock" label="Folder Restrictions"
                                        data-uid="@user.Id" data-name="@user.Username"
                                        onclick="openRestrictions(this.dataset.uid, this.dataset.name)">
                                    </sl-icon-button>
                                }
                                <sl-icon-button name="key" label="Change Password"
                                    data-uid="@user.Id" data-name="@user.Username"
                                    onclick="openChangePassword(this.dataset.uid, this.dataset.name)">
                                </sl-icon-button>
                                <sl-icon-button name="pencil" label="Edit"
                                    data-uid="@user.Id" data-display="@user.DisplayName" data-role="@user.Role"
                                    onclick="openEditUser(this.dataset.uid, this.dataset.display, this.dataset.role)">
                                </sl-icon-button>
                                @* Gemini review flagged this confirm() as an apostrophe-in-username JS bug — not a bug:
                                   `this.dataset.name` reads the DOM attribute at runtime, it is not interpolated into
                                   the onclick source string at build time. Razor HTML-encodes the attribute value
                                   (`'` → `&#x27;`) so quotes don't break parsing either. Kept as-is. *@
                                <sl-icon-button name="trash" label="Delete"
                                    data-name="@user.Username" onclick="if(confirm('Delete user ' + this.dataset.name + '?')) { document.getElementById('form-del-@user.Id').submit(); }">
                                </sl-icon-button>
                                <form id="form-del-@user.Id" method="post" asp-page-handler="Delete" style="display:none;">
                                    <input type="hidden" name="id" value="@user.Id" />
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card" style="text-align:center;padding:40px;">
            <sl-icon name="people" style="font-size:2rem;color:var(--text-secondary);display:block;margin-bottom:12px;"></sl-icon>
            <p class="text-muted">No users found</p>
        </div>
    }

    <sl-dialog id="dlg-add-user" label="Add User">
        <sl-alert id="add-user-error" variant="danger" closable style="display:none;margin-bottom:16px;">
            <sl-icon slot="icon" name="exclamation-triangle"></sl-icon>
            <span class="msg"></span>
        </sl-alert>
        <sl-alert variant="primary" open style="margin-bottom:16px;">
            <sl-icon slot="icon" name="info-circle"></sl-icon>
            This user's password is local to this node only. To allow this user to log in on other nodes,
            add them on each node separately.
        </sl-alert>
        <form id="form-add-user" onsubmit="return false;">
            <div style="margin-bottom:16px;">
                <sl-input id="add-username" name="username" label="Username" required autocomplete="off"></sl-input>
            </div>
            <div style="margin-bottom:16px;">
                <sl-input id="add-display-name" name="displayName" label="Display Name" required autocomplete="off" help-text="Leave blank to use Username"></sl-input>
            </div>
            <div style="margin-bottom:16px;">
                <sl-input id="add-password" name="password" label="Password" type="password" password-toggle required autocomplete="new-password"
                    help-text="At least 8 characters, with an uppercase letter, a lowercase letter, and a digit."></sl-input>
            </div>
            <div style="margin-bottom:16px;">
                <sl-select id="add-role" name="role" label="Role" value="user">
                    <sl-option value="superadmin">Superadmin</sl-option>
                    <sl-option value="user">User</sl-option>
                </sl-select>
            </div>
        </form>
        <sl-button slot="footer" variant="default" onclick="document.getElementById('dlg-add-user').hide()">Cancel</sl-button>
        <sl-button id="btn-add-user-submit" slot="footer" variant="primary" onclick="submitAddUser()">Create User</sl-button>
    </sl-dialog>

    <sl-dialog id="dlg-change-password" label="Change Password">
        <sl-alert id="change-password-error" variant="danger" closable style="display:none;margin-bottom:16px;">
            <sl-icon slot="icon" name="exclamation-triangle"></sl-icon>
            <span class="msg"></span>
        </sl-alert>
        <form id="form-change-password" onsubmit="return false;">
            <input type="hidden" id="cp-user-id" name="id" />
            <p id="cp-user-name" style="margin:0 0 16px;color:var(--text-secondary);"></p>
            <div style="margin-bottom:16px;">
                <sl-input id="cp-new-password" name="newPassword" label="New Password" type="password" password-toggle required autocomplete="new-password"
                    help-text="At least 8 characters, with an uppercase letter, a lowercase letter, and a digit."></sl-input>
            </div>
        </form>
        <sl-button slot="footer" variant="default" onclick="document.getElementById('dlg-change-password').hide()">Cancel</sl-button>
        <sl-button id="btn-change-password-submit" slot="footer" variant="primary" onclick="submitChangePassword()">Change Password</sl-button>
    </sl-dialog>

    <sl-dialog id="dlg-edit-user" label="Edit User">
        <sl-alert id="edit-user-error" variant="danger" closable style="display:none;margin-bottom:16px;">
            <sl-icon slot="icon" name="exclamation-triangle"></sl-icon>
            <span class="msg"></span>
        </sl-alert>
        <form id="form-edit-user" onsubmit="return false;">
            <input type="hidden" id="edit-user-id" name="id" />
            <div style="margin-bottom:16px;">
                <sl-input id="edit-display-name" name="displayName" label="Display Name" required></sl-input>
            </div>
            <div style="margin-bottom:16px;">
                <sl-select id="edit-role" name="role" label="Role">
                    <sl-option value="superadmin">Superadmin</sl-option>
                    <sl-option value="user">User</sl-option>
                </sl-select>
            </div>
        </form>
        <sl-button slot="footer" variant="default" onclick="document.getElementById('dlg-edit-user').hide()">Cancel</sl-button>
        <sl-button id="btn-edit-user-submit" slot="footer" variant="primary" onclick="submitEditUser()">Save</sl-button>
    </sl-dialog>

    <!-- Folder Restrictions Dialog -->
    <sl-dialog id="dlg-restrictions" label="Folder Access" style="--width:620px;">
        <style>
            #dlg-restrictions::part(panel) { overflow: visible; }
            #dlg-restrictions::part(body) { overflow: visible; }
            .acl-effect-option { display:flex; gap:10px; padding:12px; border:1px solid var(--sl-color-neutral-200); border-radius:8px; cursor:pointer; transition:all 0.15s; }
            .acl-effect-option:hover { border-color:var(--sl-color-primary-300); background:var(--sl-color-primary-50); }
            .acl-effect-option.selected { border-color:var(--sl-color-primary-500); background:var(--sl-color-primary-50); box-shadow:0 0 0 1px var(--sl-color-primary-500); }
            .acl-effect-option sl-icon { font-size:1.3rem; margin-top:2px; flex-shrink:0; }
            .acl-effect-option .effect-title { font-weight:600; font-size:0.92rem; }
            .acl-effect-option .effect-desc { font-size:0.82rem; color:var(--sl-color-neutral-600); margin-top:2px; line-height:1.4; }
        </style>
        <div id="restriction-user-name" style="margin-bottom:12px;font-weight:600;"></div>

        <div class="acl-help" style="background:var(--sl-color-neutral-50);border:1px solid var(--sl-color-neutral-200);border-radius:6px;padding:10px 12px;margin-bottom:14px;font-size:0.85rem;line-height:1.5;">
            <div>
                <strong>How access works.</strong>
                No rules &rarr; user sees <strong>everything</strong>.
                <strong>Deny</strong> rules hide specific folders.
                <strong>Allow</strong> rules restrict the user to <em>only</em> those folders.
                Deny always wins over Allow.
            </div>
            <sl-details summary="Show examples" style="margin-top:8px;">
                <div style="font-size:0.85rem;line-height:1.55;">
                    <p style="margin:0 0 10px;"><strong>1. Allow everything, hide a couple of folders.</strong><br>
                    Add <em>only</em> Deny rules for the folders you want to hide. No Allow rules.<br>
                    <span style="color:var(--sl-color-neutral-600);">Example: Deny <code>/HR/Salaries</code>, Deny <code>/Private</code>. User sees the rest of the tree.</span></p>

                    <p style="margin:0 0 10px;"><strong>2. Restrict user to a few folders, hide everything else.</strong><br>
                    Add <em>only</em> Allow rules for the folders you want them to see. Any folder outside becomes invisible automatically.<br>
                    <span style="color:var(--sl-color-neutral-600);">Example: Allow <code>/Team/Marketing</code>. User sees only that folder and its subfolders.</span></p>

                    <p style="margin:0;"><strong>3. Mix: allow a big branch but carve out exceptions.</strong><br>
                    Add Allow for the branch, then Deny for the subfolders inside it that should stay hidden.<br>
                    <span style="color:var(--sl-color-neutral-600);">Example: Allow <code>/Team</code>, Deny <code>/Team/Leadership</code>. User sees all of /Team except /Team/Leadership.</span></p>
                </div>
            </sl-details>
        </div>

        <!-- Folder list -->
        <div style="margin-bottom:8px;">
            <label id="folder-list-label" style="font-size:0.85rem;color:var(--sl-color-neutral-500);margin-bottom:4px;display:block;">Access Rules</label>
        </div>
        <div id="restriction-list" style="margin-bottom:16px;max-height:240px;overflow-y:auto;border:1px solid var(--sl-color-neutral-200);border-radius:4px;padding:4px 8px;">
        </div>

        <sl-alert id="restriction-error" variant="danger" closable style="display:none;margin-bottom:12px;">
            <sl-icon slot="icon" name="exclamation-triangle"></sl-icon>
            <span class="msg"></span>
        </sl-alert>

        <!-- Add new folder -->
        <div style="position:relative;">
            <div style="display:flex;gap:8px;align-items:flex-end;">
                <sl-input id="restriction-folder-search" label="Add folder" placeholder="Type to search folders..." style="flex:1;" autocomplete="off"></sl-input>
                <sl-select id="restriction-effect" label="Effect" value="deny" style="width:120px;">
                    <sl-option value="deny">Deny</sl-option>
                    <sl-option value="allow">Allow</sl-option>
                </sl-select>
                <sl-button id="btn-add-restriction" variant="primary" size="small">
                    <sl-icon slot="prefix" name="plus-lg"></sl-icon> Add
                </sl-button>
            </div>
            <div id="restriction-folder-dropdown" style="display:none;position:absolute;z-index:1000;left:0;right:56px;max-height:240px;overflow-y:auto;background:var(--sl-color-neutral-0);border:1px solid var(--sl-color-neutral-300);border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,0.15);margin-top:2px;"></div>
        </div>
    </sl-dialog>

</div>
</div>

<script>
var currentRestrictionUserId = null;
var currentRestrictionType = 'user';
var selectedFolderId = null;
var searchTimer = null;

function escapeHtml(text) {
    var d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
}

function showDlgError(alertId, message) {
    var el = document.getElementById(alertId);
    el.querySelector('.msg').textContent = message;
    el.style.display = '';
    el.open = true;
}
function hideDlgError(alertId) {
    var el = document.getElementById(alertId);
    el.open = false;
    el.style.display = 'none';
}

function validatePasswordClient(pwd) {
    if (!pwd || pwd.length < 8) return 'Password must be at least 8 characters long.';
    if (!/[A-Z]/.test(pwd)) return 'Password must contain at least one uppercase letter.';
    if (!/[a-z]/.test(pwd)) return 'Password must contain at least one lowercase letter.';
    if (!/[0-9]/.test(pwd)) return 'Password must contain at least one digit.';
    return null;
}

async function postJson(url, body, method) {
    var resp = await fetch(url, {
        method: method || 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    });
    if (resp.ok) return { ok: true };
    var msg = 'Request failed';
    try {
        var data = await resp.json();
        if (data && data.error) msg = data.error;
    } catch (e) {}
    return { ok: false, error: msg };
}

function openAddUser() {
    hideDlgError('add-user-error');
    document.getElementById('add-username').value = '';
    document.getElementById('add-display-name').value = '';
    document.getElementById('add-password').value = '';
    document.getElementById('add-role').value = 'user';
    document.getElementById('dlg-add-user').show();
    setTimeout(function() { document.getElementById('add-username').focus(); }, 100);
}

async function submitAddUser() {
    hideDlgError('add-user-error');
    var username = document.getElementById('add-username').value.trim();
    var displayName = document.getElementById('add-display-name').value.trim();
    var password = document.getElementById('add-password').value;
    var role = document.getElementById('add-role').value;

    if (!username) { showDlgError('add-user-error', 'Username is required.'); return; }
    if (!displayName) displayName = username;
    var pwdErr = validatePasswordClient(password);
    if (pwdErr) { showDlgError('add-user-error', pwdErr); return; }

    var btn = document.getElementById('btn-add-user-submit');
    btn.loading = true;
    var result = await postJson('/api-proxy/users', { username: username, displayName: displayName, password: password, role: role });
    btn.loading = false;
    if (result.ok) {
        window.location = '?msg=' + encodeURIComponent("User '" + username + "' created");
    } else {
        showDlgError('add-user-error', result.error);
    }
}

function openChangePassword(userId, username) {
    hideDlgError('change-password-error');
    document.getElementById('cp-user-id').value = userId;
    document.getElementById('cp-user-name').textContent = 'User: ' + username;
    document.getElementById('cp-new-password').value = '';
    document.getElementById('dlg-change-password').show();
    setTimeout(function() { document.getElementById('cp-new-password').focus(); }, 100);
}

async function submitChangePassword() {
    hideDlgError('change-password-error');
    var id = document.getElementById('cp-user-id').value;
    var newPassword = document.getElementById('cp-new-password').value;
    var pwdErr = validatePasswordClient(newPassword);
    if (pwdErr) { showDlgError('change-password-error', pwdErr); return; }

    var btn = document.getElementById('btn-change-password-submit');
    btn.loading = true;
    var result = await postJson('/api-proxy/users/' + id + '/change-password', { newPassword: newPassword });
    btn.loading = false;
    if (result.ok) {
        window.location = '?msg=' + encodeURIComponent('Password changed');
    } else {
        showDlgError('change-password-error', result.error);
    }
}

function openEditUser(userId, displayName, role) {
    hideDlgError('edit-user-error');
    document.getElementById('edit-user-id').value = userId;
    document.getElementById('edit-display-name').value = displayName;
    document.getElementById('edit-role').value = role;
    document.getElementById('dlg-edit-user').show();
}

async function submitEditUser() {
    hideDlgError('edit-user-error');
    var id = document.getElementById('edit-user-id').value;
    var displayName = document.getElementById('edit-display-name').value.trim();
    var role = document.getElementById('edit-role').value;
    if (!displayName) { showDlgError('edit-user-error', 'Display Name is required.'); return; }

    var btn = document.getElementById('btn-edit-user-submit');
    btn.loading = true;
    var result = await postJson('/api-proxy/users/' + id, { displayName: displayName, role: role }, 'PUT');
    btn.loading = false;
    if (result.ok) {
        window.location = '?msg=' + encodeURIComponent('User updated');
    } else {
        showDlgError('edit-user-error', result.error);
    }
}

// Enter key submits the active dialog
['form-add-user', 'form-change-password', 'form-edit-user'].forEach(function(fid) {
    var handlers = { 'form-add-user': submitAddUser, 'form-change-password': submitChangePassword, 'form-edit-user': submitEditUser };
    var form = document.getElementById(fid);
    form.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && e.target.tagName && e.target.tagName.toLowerCase() !== 'textarea') {
            e.preventDefault();
            handlers[fid]();
        }
    });
});


function openRestrictions(userId, userName) {
    currentRestrictionUserId = userId;
    currentRestrictionType = 'user';
    document.getElementById('restriction-user-name').textContent = 'User: ' + userName;
    loadRestrictions();
    selectedFolderId = null;
    document.getElementById('restriction-folder-search').value = '';
    document.getElementById('restriction-folder-dropdown').style.display = 'none';
    document.getElementById('restriction-effect').value = 'deny';
    hideDlgError('restriction-error');
    document.getElementById('dlg-restrictions').show();
}

function loadRestrictions() {
    var url = '/api-proxy/restrictions/' + currentRestrictionType + '/' + currentRestrictionUserId;
    fetch(url).then(function(r) { return r.json(); }).then(function(list) {
        var container = document.getElementById('restriction-list');
        if (!list || list.length === 0) {
            container.innerHTML = '<div style="color:var(--sl-color-neutral-500);font-size:0.9rem;">No access rules — user can see everything</div>';
            return;
        }
        container.innerHTML = list.map(function(r) {
            var effectIcon = r.effect === 'allow' ? 'check-circle' : 'x-circle';
            var effectColor = r.effect === 'allow' ? 'var(--sl-color-success-600)' : 'var(--sl-color-danger-600)';
            var effectLabel = r.effect === 'allow' ? 'Allow' : 'Deny';
            return '<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--sl-color-neutral-200);">' +
                '<span><sl-icon name="folder2"></sl-icon> ' + escapeHtml(r.folderPath) +
                ' <sl-badge variant="' + (r.effect === 'allow' ? 'success' : 'danger') + '" pill style="margin-left:8px;">' + effectLabel + '</sl-badge></span>' +
                '<sl-icon-button name="trash" label="Remove" onclick="removeRestriction(\'' + r.folderId + '\')"></sl-icon-button>' +
                '</div>';
        }).join('');
    }).catch(function() {
        document.getElementById('restriction-list').innerHTML = '<div style="color:var(--sl-color-danger);font-size:0.9rem;">Failed to load restrictions</div>';
    });
}

var folderSearchInput = document.getElementById('restriction-folder-search');
var folderDropdown = document.getElementById('restriction-folder-dropdown');
var addBtn = document.getElementById('btn-add-restriction');

folderSearchInput.addEventListener('sl-input', function() {
    selectedFolderId = null;
    hideDlgError('restriction-error');
    clearTimeout(searchTimer);
    var q = folderSearchInput.value.trim();
    if (q.length < 1) { folderDropdown.style.display = 'none'; return; }
    searchTimer = setTimeout(function() { searchFolders(q); }, 250);
});

async function searchFolders(q) {
    try {
        var resp = await fetch('/api-proxy/folders/search?q=' + encodeURIComponent(q) + '&limit=50');
        var data = await resp.json();
        var currentRestrictions = await fetch('/api-proxy/restrictions/' + currentRestrictionType + '/' + currentRestrictionUserId).then(function(r) { return r.json(); });
        var restrictedIds = new Set(currentRestrictions.map(function(r) { return r.folderId; }));
        var folders = (data.folders || []).filter(function(f) { return !restrictedIds.has(f.id); });
        folders.sort(function(a, b) {
            return a.path.length - b.path.length || a.path.localeCompare(b.path);
        });

        if (folders.length === 0) {
            folderDropdown.innerHTML = '<div style="padding:8px 12px;color:var(--sl-color-neutral-500);font-size:0.9rem;">No matching folders</div>';
        } else {
            folderDropdown.innerHTML = folders.map(function(f) {
                return '<div class="folder-search-item" data-id="' + f.id + '" data-path="' + escapeHtml(f.path) + '" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid var(--sl-color-neutral-100);">' +
                    '<sl-icon name="folder2" style="margin-right:6px;"></sl-icon>' + escapeHtml(f.path) + '</div>';
            }).join('');
            if (data.hasMore) {
                folderDropdown.innerHTML += '<div style="padding:6px 12px;color:var(--sl-color-neutral-400);font-size:0.8rem;text-align:center;">Type more to narrow results...</div>';
            }
        }
        folderDropdown.style.display = 'block';
    } catch (e) {
        folderDropdown.innerHTML = '<div style="padding:8px 12px;color:var(--sl-color-danger-600);">Search failed</div>';
        folderDropdown.style.display = 'block';
    }
}

folderDropdown.addEventListener('click', function(e) {
    var item = e.target.closest('.folder-search-item');
    if (!item) return;
    selectedFolderId = item.dataset.id;
    folderSearchInput.value = item.dataset.path;
    folderDropdown.style.display = 'none';
    hideDlgError('restriction-error');
});

folderDropdown.addEventListener('mouseover', function(e) {
    var item = e.target.closest('.folder-search-item');
    if (item) item.style.background = 'var(--sl-color-primary-50)';
});
folderDropdown.addEventListener('mouseout', function(e) {
    var item = e.target.closest('.folder-search-item');
    if (item) item.style.background = '';
});

document.addEventListener('click', function(e) {
    if (!e.target.closest('#restriction-folder-search') && !e.target.closest('#restriction-folder-dropdown')) {
        folderDropdown.style.display = 'none';
    }
});

async function resolveFolderByPath(path) {
    var resp = await fetch('/api-proxy/folders/search?q=' + encodeURIComponent(path) + '&limit=100');
    if (!resp.ok) return null;
    var data = await resp.json();
    var folders = data.folders || [];
    if (folders.length === 0) return null;

    // Normalize: strip trailing slash(es), lower-case, ensure leading slash.
    var needle = path.replace(/\/+$/, '').toLowerCase();
    if (!needle.startsWith('/')) needle = '/' + needle;

    // Server already sorted shortest-path-first, so the first match wins
    // when multiple folders share the same last segment.

    // 1. Exact full-path match.
    for (var i = 0; i < folders.length; i++) {
        var p = folders[i].path.replace(/\/+$/, '').toLowerCase();
        if (p === needle) return folders[i];
    }

    // 2. Fallback: last-segment match (user typed a folder name like "uManage").
    var segment = needle.split('/').pop();
    if (segment) {
        for (var j = 0; j < folders.length; j++) {
            var lastSeg = folders[j].path.replace(/\/+$/, '').split('/').pop().toLowerCase();
            if (lastSeg === segment) return folders[j];
        }
    }
    return null;
}

async function addRestriction() {
    hideDlgError('restriction-error');
    var typed = folderSearchInput.value.trim();
    if (!typed) {
        showDlgError('restriction-error', 'Enter a folder path or pick one from the list.');
        return;
    }

    var folderId = selectedFolderId;
    if (!folderId) {
        addBtn.loading = true;
        var match = await resolveFolderByPath(typed);
        addBtn.loading = false;
        if (!match) {
            showDlgError('restriction-error', "Folder '" + typed + "' not found.");
            return;
        }
        folderId = match.id;
    }

    addBtn.loading = true;
    var effect = document.getElementById('restriction-effect').value || 'deny';
    var resp = await fetch('/api-proxy/restrictions/' + currentRestrictionType + '/' + currentRestrictionUserId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ folderId: folderId, effect: effect })
    });
    addBtn.loading = false;
    if (resp.ok) {
        selectedFolderId = null;
        folderSearchInput.value = '';
        folderDropdown.style.display = 'none';
        loadRestrictions();
    } else {
        var msg = 'Failed to add restriction';
        try { var data = await resp.json(); if (data && data.error) msg = data.error; } catch (e) {}
        showDlgError('restriction-error', msg);
    }
}

function removeRestriction(folderId) {
    fetch('/api-proxy/restrictions/' + currentRestrictionType + '/' + currentRestrictionUserId + '/' + folderId, {
        method: 'DELETE'
    }).then(function(r) {
        if (r.ok) {
            loadRestrictions();
        } else {
            showDlgError('restriction-error', 'Failed to remove restriction');
        }
    });
}

addBtn.addEventListener('click', addRestriction);
</script>
