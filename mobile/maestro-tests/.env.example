# Maestro test environment variables
# Copy this file to .env and fill in your test node values
#
# Usage:
#   maestro test --env-file mobile/maestro-tests/.env mobile/maestro-tests/
#   OR export these variables before running tests

# Display name for the test node
BMB_TEST_NODE_NAME=My Test Node

# Your BeeMemoryBank test server address (host:port)
BMB_TEST_SERVER=192.168.1.x:5300

# Password for the test node (NOT a production password)
BMB_TEST_PASSWORD=YourTestPasswordHere
