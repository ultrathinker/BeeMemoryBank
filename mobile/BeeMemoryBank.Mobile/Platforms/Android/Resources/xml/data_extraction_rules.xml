<?xml version="1.0" encoding="utf-8"?>
<!--
  E2E-encrypted data must never be backed up to Google Drive (Auto Backup) or
  transferred via Device-to-Device migration. The schema/keys can desync against
  peers; recovery is via re-join from a peer, not via cloud restore.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
