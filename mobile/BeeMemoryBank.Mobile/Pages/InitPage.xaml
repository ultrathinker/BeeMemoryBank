<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BeeMemoryBank.Mobile.Pages.InitPage"
             Title="BeeMemoryBank Setup"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="400"
                              HorizontalOptions="Center" VerticalOptions="Center">

            <Label Text="BeeMemoryBank"
                   Style="{StaticResource TitleLabel}"
                   HorizontalOptions="Center"
                   FontSize="32" />

            <Label Text="Setup your node"
                   Style="{StaticResource SubtitleLabel}"
                   HorizontalOptions="Center" />

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Node Name" Style="{StaticResource BaseLabel}" FontAttributes="Bold" />
                    <Entry x:Name="NameEntry"
                           AutomationId="NameEntry"
                           Placeholder="e.g. My Phone"
                           Style="{StaticResource BaseEntry}" />

                    <Label Text="Password" Style="{StaticResource BaseLabel}" FontAttributes="Bold" />
                    <Entry x:Name="PasswordEntry"
                           AutomationId="PasswordEntry"
                           Placeholder="Encryption password"
                           IsPassword="True"
                           Style="{StaticResource BaseEntry}" />

                    <Label Text="Confirm Password" Style="{StaticResource BaseLabel}" FontAttributes="Bold" />
                    <Entry x:Name="ConfirmPasswordEntry"
                           AutomationId="ConfirmPasswordEntry"
                           Placeholder="Confirm password"
                           IsPassword="True"
                           Style="{StaticResource BaseEntry}" />

                    <Label x:Name="ErrorLabel"
                           TextColor="{StaticResource ErrorColor}"
                           IsVisible="False"
                           FontSize="14" />

                    <Button x:Name="InitButton"
                            AutomationId="InitButton"
                            Text="Initialize Node"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnInitClicked" />

                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource PrimaryColor}" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Already have a node? Join existing network"
                   HorizontalOptions="Center"
                   FontSize="14"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnJoinTapped" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
