<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BeeMemoryBank.Mobile.Pages.FolderPickerPage"
             Title="Choose Folder"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*,Auto">

        <SearchBar Grid.Row="0" x:Name="SearchBar"
                   AutomationId="FolderSearchBar"
                   Placeholder="Search folders..."
                   TextChanged="OnSearchTextChanged"
                   Style="{StaticResource BaseSearchBar}"
                   Margin="8,8,8,0" />

        <CollectionView Grid.Row="1" x:Name="FolderList"
                        AutomationId="FolderPickerList"
                        SelectionMode="None"
                        Margin="8,8,8,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame x:Name="NodeFrame" Margin="{Binding DepthMargin}" Padding="12,8">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#1ae91e63" />
                            </DataTrigger>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                            </DataTrigger>
                        </Frame.Triggers>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFolderTapped" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding Arrow}"
                                   FontSize="14"
                                   VerticalOptions="Center"
                                   WidthRequest="16" />
                            <Label Text="{Binding Icon}" FontSize="16" VerticalOptions="Center" />
                            <Label Text="{Binding Name}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Padding="12,8" RowDefinitions="48">
            <Button Grid.Column="0" Text="New Folder"
                    AutomationId="NewFolderButton"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnNewFolderClicked"
                    HorizontalOptions="Fill" />
            <Label Grid.Column="1" x:Name="SelectedPathLabel"
                   AutomationId="SelectedPathLabel"
                   Text="/"
                   FontSize="13"
                   LineBreakMode="MiddleTruncation"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{StaticResource SecondaryTextColor}" />
            <Button Grid.Column="2" x:Name="SelectButton"
                    AutomationId="SelectFolderButton"
                    Text="Select"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Clicked="OnSelectClicked"
                    HorizontalOptions="Fill" />
        </Grid>

    </Grid>

</ContentPage>
