<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BeeMemoryBank.Mobile.Pages.TagsPage"
             Title="Tags"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*">

        <ActivityIndicator x:Name="LoadingIndicator"
                           Grid.Row="0" Grid.RowSpan="2"
                           IsRunning="False"
                           IsVisible="False"
                           Color="{StaticResource PrimaryColor}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           ZIndex="10" />

        <SearchBar Grid.Row="0"
                   x:Name="TagsSearchBar"
                   AutomationId="TagsSearchBar"
                   Placeholder="Search tags..."
                   TextChanged="OnSearchTextChanged"
                   Style="{StaticResource BaseSearchBar}"
                   Margin="8,8,8,0" />

        <RefreshView Grid.Row="1" x:Name="RefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="TagsList"
                            AutomationId="TagsList"
                            SelectionMode="None"
                            Margin="8,8,8,0">
                <CollectionView.EmptyView>
                    <StackLayout Padding="16" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="No tags found"
                               TextColor="{StaticResource SecondaryTextColor}"
                               FontSize="16"
                               HorizontalOptions="Center" />
                    </StackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTagTapped" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Count}"
                                       FontSize="14"
                                       TextColor="{StaticResource SecondaryTextColor}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="2"
                                        Text="⋮"
                                        FontSize="18"
                                        WidthRequest="40"
                                        HeightRequest="36"
                                        Padding="0"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource SecondaryTextColor}"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnTagOptionsClicked" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
