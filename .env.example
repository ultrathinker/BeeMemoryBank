# BeeMemoryBank — Docker environment configuration
# Copy this file to .env and edit as needed:
#   cp .env.example .env

# Host ports (optional, defaults shown)
# BMB_API_PORT=5300   # REST API + MCP server (for AI agents, bmb CLI)
# BMB_WEB_PORT=5301   # Web UI (for browser)

# Data directory on host (optional, defaults to ./data)
# BMB_DATA_PATH=./data
